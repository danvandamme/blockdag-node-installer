# Copy to .env. The installer does this for you and writes the same file to
# asic-pool/.env so Compose interpolation and the pool runtime stay aligned.

POOL_IMAGE=bdag-release/asic-pool:local
BLOCKDAG_NODE_IMAGE=bdag-release/node:local

# Replace with the reward wallet address for this pool.
MINING_ADDRESS=0x0000000000000000000000000000000000000000
POOL_PRIVATE_KEY=

POOL_PORT=3334
BDAG_RPC_PORT=38131
NODE1_P2P_PORT=8151
NODE2_P2P_PORT=8152
# Public IP advertised to the BlockDAG P2P network so inbound peers can reach this node.
# Set this to your static public IP if you have port 8151/8152 forwarded from your router.
# Leave blank if you don't have port forwarding (node will still work, just outbound-only).
NODE_EXTERNAL_IP=
NODE1_METRICS_PORT=6061
NODE2_METRICS_PORT=6062
POSTGRES_PORT=5432

NODE_RPC_USER=test
NODE_RPC_PASS=test
POSTGRES_USER=test
POSTGRES_PASSWORD=test
POSTGRES_DB=pool
PG_URL=postgres://test:test@pool-db:5432/pool

# Space-separated --addpeer flags, managed by the dashboard peer manager.
# These 4 are the known BlockDAG bootstrap nodes; add more via the dashboard.
NODE1_ADDPEER_FLAGS=--addpeer=/ip4/3.214.202.100/tcp/8150/p2p/16Uiu2HAmGVzwYkqmGjnpniD9PZx7GPoDcMudxjNSzbFzBgFviRac --addpeer=/ip4/3.6.3.109/tcp/8150/p2p/16Uiu2HAm233S37d2Jtw5PPYe6dpwqUwNKpgvbiuNuV6DJ1QtbrSW --addpeer=/ip4/54.151.18.92/tcp/8150/p2p/16Uiu2HAmVm91o1JXS2C7P6uTVuVX5empgnRtzuK4UaC8fHmePbKP --addpeer=/ip4/52.8.54.60/tcp/8150/p2p/16Uiu2HAkzUWr4YUM7mAhLdCVZgFoV9He6aQzKTyWWrJ7SWQKRTN7
NODE2_ADDPEER_FLAGS=--addpeer=/ip4/3.214.202.100/tcp/8150/p2p/16Uiu2HAmGVzwYkqmGjnpniD9PZx7GPoDcMudxjNSzbFzBgFviRac --addpeer=/ip4/3.6.3.109/tcp/8150/p2p/16Uiu2HAm233S37d2Jtw5PPYe6dpwqUwNKpgvbiuNuV6DJ1QtbrSW --addpeer=/ip4/54.151.18.92/tcp/8150/p2p/16Uiu2HAmVm91o1JXS2C7P6uTVuVX5empgnRtzuK4UaC8fHmePbKP --addpeer=/ip4/52.8.54.60/tcp/8150/p2p/16Uiu2HAkzUWr4YUM7mAhLdCVZgFoV9He6aQzKTyWWrJ7SWQKRTN7

POOL_STARTING_PDIFF=1.0
PPLNS_N_WORK=1000
POOL_BLOCK_MATURITY=10
POOL_PAYOUT_MATURITY=50
POOL_FEE_PERCENTAGE=2.0
POOL_SUBMIT_STALE_BLOCK_CANDIDATES=true
POOL_GLOBAL_BLOCK_DEDUPE_ENABLED=true
POOL_LOW_DIFF_FLOOD_DISCONNECT_ENABLED=true
POOL_LOW_DIFF_REJECT_WINDOW_SECONDS=30
POOL_LOW_DIFF_REJECT_DISCONNECT_THRESHOLD=250

POOL_RPC_ROUTER_ENABLED=true
POOL_RPC_BACKENDS=node1=http://bdag-miner-node-1:38131,node2=http://bdag-miner-node-2:38131
POOL_RPC_ROUTER_MIN_HEALTHY_SECONDS=20
POOL_RPC_ROUTER_SWITCH_COOLDOWN_SECONDS=45
POOL_RPC_ROUTER_TEMPLATE_MAX_AGE_SECONDS=90
POOL_RPC_ROUTER_FREEZE_FAILOVER_ENABLED=true
POOL_RPC_ROUTER_FREEZE_FAILOVER_AFTER_SECONDS=45
POOL_RPC_ROUTER_FREEZE_MAX_TEMPLATE_AGE_SECONDS=90
POOL_RPC_ROUTER_RECOVERY_PROBE_SECONDS=20

POOL_REFRESH_LOG_INTERVAL_SECONDS=60
POOL_DB_SUCCESS_LOG_INTERVAL_SECONDS=60
POOL_DIFFICULTY_PUSH_LOG_INTERVAL_SECONDS=60
POOL_CREDIT_DETAIL_LOG_INTERVAL_SECONDS=60

# Installer adjusts these for low-memory systems.
NODE_CACHE_MB=4096
NODE_DAG_CACHE=8000
NODE_BD_CACHE=8000
NODE_MAX_PEERS=350
NODE_RPC_MAX_CONCURRENT=500
NODE_HTTP_RATE_LIMIT=1800
NODE_HTTP_RATE_BURST=3200
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=2GB
POSTGRES_MAX_WAL_SIZE=2GB
POSTGRES_CHECKPOINT_TIMEOUT=15min

POOL_CPU_SHARES=3072
NODE_CPU_SHARES=4096
POSTGRES_CPU_SHARES=3072
RPC_FAILOVER_CPU_SHARES=2048

# Dashboard/watchdog installer defaults.
BDAG_DASHBOARD_BIND=127.0.0.1
BDAG_DASHBOARD_PORT=8088
BDAG_DASHBOARD_REQUIRE_TOKEN=auto
BDAG_POOL_HOST=
BDAG_POOL_URL=
# Comma-separated IPs (or IP:port) of remote DagTech miners the dashboard should
# poll for live stats.  Each reachable miner shows as a separate row in the
# workers table.  Example: 192.168.4.170 or 192.168.4.170:8880,192.168.4.171
BDAG_MINER_SCAN_TARGET=
BDAG_MINER_POOL_PASSWORD=
INSTALLER_VERSION=DVD-2026.0526.1
